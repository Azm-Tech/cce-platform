{
  "name": "api-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/api-client/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/api-client/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/api-client/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/api-client/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/api-client/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "refresh-contracts": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "curl -sf https://cce-external-api.runasp.net/swagger/external/v1/swagger.json -o ../contracts/openapi.external.json",
          "curl -sf https://cce-internal-api.runasp.net/swagger/internal/v1/swagger.json -o ../contracts/openapi.internal.json"
        ],
        "parallel": true
      }
    },
    "generate-types": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/lib/schema"],
      "dependsOn": ["refresh-contracts"],
      "options": {
        "commands": [
          "./node_modules/.bin/openapi-typescript ../contracts/openapi.external.json -o libs/api-client/src/lib/schema/external.ts",
          "./node_modules/.bin/openapi-typescript ../contracts/openapi.internal.json -o libs/api-client/src/lib/schema/internal.ts"
        ],
        "parallel": false
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/lib/generated"],
      "options": {
        "commands": [
          "./node_modules/.bin/openapi-ts -i ../contracts/openapi.external.json -o libs/api-client/src/lib/generated/external -c @hey-api/client-fetch",
          "./node_modules/.bin/openapi-ts -i ../contracts/openapi.internal.json -o libs/api-client/src/lib/generated/internal -c @hey-api/client-fetch",
          "for f in libs/api-client/src/lib/generated/external/*.ts libs/api-client/src/lib/generated/internal/*.ts; do head -1 \"$f\" | grep -q '@ts-nocheck' || (printf '// @ts-nocheck\\n'; cat \"$f\") > \"$f.tmp\" && mv \"$f.tmp\" \"$f\"; done"
        ],
        "parallel": false
      }
    }
  }
}
