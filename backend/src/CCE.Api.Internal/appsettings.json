{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Assistant": {
    "Provider": "stub",
    "Anthropic": {
      "Model": "claude-sonnet-4-5-20250929",
      "MaxTokens": 1024,
      "Temperature": 0.3
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "FileSink": {
      "Enabled": true,
      "Path": "logs/cce-.log",
      "RetainedDays": 7
    }
  }
}
